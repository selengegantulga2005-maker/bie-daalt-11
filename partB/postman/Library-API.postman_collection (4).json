                "members",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Тест хэрэглэгч\", \"email\": \"test@example.com\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Has id\", () => { const j = pm.response.json(); pm.expect(j).to.have.property('id'); });"
                ]
              }
            }
          ]
        },
